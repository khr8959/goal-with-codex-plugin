{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/khr8959/goal-dual-plugin/schemas/state.schema.json",
  "title": "goal-dual state",
  "type": "object",
  "required": [
    "goal_text",
    "iteration",
    "completed",
    "loop_phase",
    "scope_mode"
  ],
  "properties": {
    "goal_text": {
      "type": "string",
      "minLength": 1
    },
    "eval_cmd": {
      "type": ["string", "null"]
    },
    "eval_cmd_source": {
      "type": "string"
    },
    "base_branch": {
      "type": ["string", "null"]
    },
    "branch": {
      "type": "string"
    },
    "branch_auto_created": {
      "type": "boolean"
    },
    "no_git": {
      "type": "boolean"
    },
    "iteration": {
      "type": "integer",
      "minimum": 0
    },
    "completed": {
      "type": "boolean"
    },
    "stop_reason": {
      "enum": [
        null,
        "COMPLETE",
        "STOP_HUMAN",
        "STOP_STAGNANT",
        "STOP_DIRTY",
        "STOP_SCOPE",
        "STOP_CODEX",
        "STOP_HIGH_RISK"
      ]
    },
    "loop_phase": {
      "enum": [
        "iterating",
        "delegating_to_codex",
        "awaiting_claude_review",
        "await_final_check",
        "await_code_review"
      ]
    },
    "last_step_status": {
      "enum": [
        "awaiting_claude_review",
        "needs_fix",
        "stopped",
        "unknown"
      ]
    },
    "scope_allow": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scope_deny": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scope_mode": {
      "enum": ["enforce", "advisory"]
    },
    "codex_plugin_root": {
      "type": "string"
    },
    "goal_dual_plugin_root": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
