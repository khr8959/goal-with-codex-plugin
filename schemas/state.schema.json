{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/khr8959/goal-with-codex-plugin/schemas/state.schema.json",
  "title": "goal-with-codex state",
  "type": "object",
  "required": [
    "schema",
    "created_at",
    "iteration",
    "completed",
    "loop_phase",
    "user_goal",
    "technical_goal",
    "acceptance_criteria",
    "codex_plugin_root",
    "goal_with_codex_plugin_root"
  ],
  "properties": {
    "schema": {
      "const": "goal-with-codex.state.v1"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "user_goal": {
      "type": "string",
      "minLength": 1
    },
    "technical_goal": {
      "type": "string",
      "minLength": 1
    },
    "acceptance_criteria": {
      "type": "string"
    },
    "constraints": {
      "type": "string"
    },
    "non_goals": {
      "type": "string"
    },
    "eval_cmd": {
      "type": ["string", "null"]
    },
    "eval_cmd_source": {
      "type": "string"
    },
    "branch": {
      "type": "string"
    },
    "iteration": {
      "type": "integer",
      "minimum": 0
    },
    "completed": {
      "type": "boolean"
    },
    "stop_reason": {
      "type": ["string", "null"]
    },
    "loop_phase": {
      "enum": [
        "initialized",
        "awaiting_claude_review",
        "needs_fix",
        "stopped"
      ]
    },
    "last_action": {
      "type": ["string", "null"]
    },
    "codex_plugin_root": {
      "type": "string"
    },
    "goal_with_codex_plugin_root": {
      "type": "string"
    },
    "routing_policy_version": {
      "type": "integer"
    }
  },
  "additionalProperties": true
}
