{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/khr8959/goal-with-codex-plugin/schemas/evidence.schema.json",
  "title": "goal-with-codex evidence packet",
  "type": "object",
  "required": [
    "schema",
    "created_at",
    "iteration",
    "status",
    "recommendation",
    "trigger",
    "codex_action",
    "codex",
    "eval",
    "changed_files",
    "next_commands"
  ],
  "properties": {
    "schema": {
      "const": "goal-with-codex.evidence.v1"
    },
    "created_at": {
      "type": "string"
    },
    "iteration": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "enum": ["awaiting_claude_review", "needs_fix", "stopped"]
    },
    "recommendation": {
      "type": "string"
    },
    "trigger": {
      "type": "string"
    },
    "codex_action": {
      "enum": ["task", "task_resume"]
    },
    "codex": {
      "type": "object",
      "required": ["risk", "task_ref"],
      "properties": {
        "risk": {
          "enum": ["low", "medium", "high"]
        },
        "task_ref": {
          "type": "string"
        },
        "task": {
          "type": ["object", "null"]
        }
      },
      "additionalProperties": true
    },
    "review": {
      "type": "object",
      "additionalProperties": true
    },
    "eval": {
      "type": "object",
      "required": ["command", "label", "exit_code", "output_ref"],
      "properties": {
        "command": {
          "type": ["string", "null"]
        },
        "label": {
          "enum": ["passed", "failed", "skipped"]
        },
        "exit_code": {
          "type": ["string", "null"]
        },
        "output_ref": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
